{
    "name": "jdz/image",
    "type": "library",
    "description": "JDZ Image utils",
    "keywords": [
        "JDZ",
        "utilities",
        "image",
        "template"
    ],
    "homepage": "https://jdz.joffreydemetz.com/image",
    "license": "MIT",
    "authors": [
        {
            "name": "Joffrey Demetz",
            "email": "joffrey.demetz@gmail.com",
            "homepage": "https://joffreydemetz.com",
            "role": "Lead"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/filesystem": "^7.4",
        "symfony/finder": "^7.4",
        "imagine/imagine": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "JDZ\\Image\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JDZ\\Image\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always --testdox",
        "test-coverage": "phpunit --coverage-html coverage"
    }
}